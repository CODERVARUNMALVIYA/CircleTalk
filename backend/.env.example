# Server Configuration
PORT=5001
NODE_ENV=development

# Database (either works, MONGO_URI preferred)
MONGO_URI=your_mongodb_connection_string
MONGODB_URI=your_mongodb_connection_string

# JWT Secret
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_characters

# Stream Chat (Optional)
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# Frontend URL(s) for CORS (comma-separated)
FRONTEND_URL=http://localhost:5173,https://circletalk-1.onrender.com
